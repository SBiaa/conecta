// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Papel {
  ADMIN
  PROFESSOR
  ASSOCIADO
}

enum Status {
  ATIVO
  INATIVO
}

enum StatusPagamento {
  PENDENTE
  PAGA
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO
}

enum ExameMedico {
  APTO
  NAO_APTO
  AGUARDANDO
}

enum TipoPost {
  GERAL
  PROJETO
  TURMA
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  cpf       String   @unique
  senha     String
  email     String?  @unique
  telefone  String?
  papel     Papel    @default(ASSOCIADO)
  status    Status   @default(ATIVO)
  criadoEm  DateTime @default(now())
cep         String?
  logradouro  String?   // a rua
  numero      String?   // texto, não número — por causa de "123A", "s/n"
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?   // o estado, 2 letras (SP, RJ...)
  rg               String?
  dataNascimento   DateTime?
  tomaMedicamento  Boolean   @default(false)
  qualMedicamento  String?
  matriculas Matricula[]
  turmasComoProfessor Turma[]    @relation("TurmaProfessor")
  presencasRegistradas Presenca[] @relation("PresencaRegistradaPor")
  posts Post[]
}

model Projeto {
  id       Int      @id @default(autoincrement())
  nome     String
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  turmas Turma[]
  posts  Post[]
}

model Turma {
  id        Int      @id @default(autoincrement())
  nome      String
  projetoId Int
  projeto   Projeto  @relation(fields: [projetoId], references: [id])
  criadoEm  DateTime @default(now())

  matriculas Matricula[]
    dias      DiaSemana[]
  horario   String?

  professorId String?
  professor   Usuario? @relation("TurmaProfessor", fields: [professorId], references: [id])
  presencas   Presenca[]
  posts       Post[]
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Matricula {
  id         Int      @id @default(autoincrement())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  turmaId    Int
  turma      Turma    @relation(fields: [turmaId], references: [id])
  ativa      Boolean  @default(true)
  dataInicio DateTime @default(now())
exameMedico  ExameMedico  @default(AGUARDANDO)
  pagamentos Pagamento[]
  presencas  Presenca[]
}

model Presenca {
  id              Int       @id @default(autoincrement())
  matriculaId     Int
  matricula       Matricula @relation(fields: [matriculaId], references: [id])
  turmaId         Int
  turma           Turma     @relation(fields: [turmaId], references: [id])
  data            DateTime  @db.Date
  presente        Boolean
  registradoPorId String
  registradoPor   Usuario   @relation("PresencaRegistradaPor", fields: [registradoPorId], references: [id])
  criadoEm        DateTime  @default(now())

  @@unique([matriculaId, data])
}

model Pagamento {
  id             Int             @id @default(autoincrement())
  matriculaId    Int
  matricula      Matricula       @relation(fields: [matriculaId], references: [id])
  valor          Decimal         @db.Decimal(10, 2)
  mesReferencia  String
  vencimento     DateTime
  status         StatusPagamento @default(PENDENTE)
  dataPagamento  DateTime?
  formaPagamento FormaPagamento?
  criadoEm       DateTime        @default(now())
}

model Post {
  id        Int      @id @default(autoincrement())
  conteudo  String
  tipo      TipoPost
  autorId   String
  autor     Usuario  @relation(fields: [autorId], references: [id])
  projetoId Int?
  projeto   Projeto? @relation(fields: [projetoId], references: [id])
  turmaId   Int?
  turma     Turma?   @relation(fields: [turmaId], references: [id])
  criadoEm  DateTime @default(now())
}
